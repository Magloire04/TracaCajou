# ── TraçaCajou · variables d'environnement (exemple) ───────────────
# Copier en .env (back) / .env local (front). NE JAMAIS committer le .env réel.
# Convention : SCREAMING_SNAKE_CASE. Secrets → vault en prod, jamais en dur.

# ─── Back-end (Laravel) ───────────────────────────────────────────
APP_NAME=TracaCajou
APP_ENV=local                      # local | staging | production
APP_KEY=                           # php artisan key:generate
APP_DEBUG=true                     # FALSE en production (pas de stack trace exposée)
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tracacajou
DB_USERNAME=tracacajou
DB_PASSWORD=                       # secret — vault en prod

# Auth (JWT en cookie httpOnly + secure, jamais en localStorage)
JWT_SECRET=                        # secret — vault en prod
SESSION_SECURE_COOKIE=true         # true en prod (HTTPS)

# Signature des certificats (ECDSA P-384) — clé hors dépôt
CERT_SIGNING_PRIVATE_KEY_PATH=/etc/tracacajou/keys/p384-private.pem
CERT_SIGNING_PUBLIC_KEY_PATH=/etc/tracacajou/keys/p384-public.pem
CERT_PUBLIC_VERIFY_BASE_URL=https://verify.tracacajou.bj

# ─── Front-end (Nuxt / PWA) ───────────────────────────────────────
# Préfixe public obligatoire pour l'exposition côté client
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=TracaCajou
